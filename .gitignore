# ==========================================
# CRITICAL: SECRET & CREDENTIAL BLOCKING
# ==========================================
# Blocks your private API keys (OpenAI, AWS secrets)
.env
.env.local

# ==========================================
# PYTHON VIRTUAL ENVIRONMENTS
# ==========================================
# Blocks the massive, non-portable library folders
.venv/
env/
venv/
ENV/

# ==========================================
# PYTHON CACHE & SYSTEM FILES
# ==========================================
# Blocks compiled bytecode (like the main.cpython-313.pyc file)
__pycache__/
*.pyc
*.pyo
*.pyd

# ==========================================
# LOCAL DATA & OUTPUTS
# ==========================================
# Blocks the CSV sheets generated by your Pandas script
ebay-new.csv